---
/**
 * DrupalX — single-page marketing site.
 * Astro 5 + Tailwind v4 (CSS-first tokens in src/styles/global.css).
 */
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import { Icon } from 'astro-icon/components';

const GITHUB = 'https://github.com/nextagencyio/drupalx-project';

const features = [
  {
    icon: 'lucide:layout-template',
    c: 'sky',
    title: 'Canvas page building',
    body: 'Every landing page is composed in Drupal Canvas (Experience Builder). Editors drag components, fill in form fields, and nest cards into grids — no developer round-trip.',
  },
  {
    icon: 'lucide:palette',
    c: 'clay',
    title: 'A real design system',
    body: 'Tailwind v4 CSS-first tokens: a full brand scale, two wayfinding color families, editorial display type, and polished hover states — enforced by component schemas, not style guides.',
  },
  {
    icon: 'lucide:zap',
    c: 'accent',
    title: 'Fast by default',
    body: 'Self-hosted variable fonts, build-time Lucide icons inlined as SVG, and width-stepped WebP images via dx_image. Zero CDN dependencies anywhere.',
  },
  {
    icon: 'lucide:blocks',
    c: 'none',
    title: '24 components, day one',
    body: 'Heroes (glass, split, dark), stat bands, card grids, splits, CTAs, quotes, galleries, accordions, alerts, news & event cards, document lists — plus the primitives.',
  },
  {
    icon: 'lucide:eye',
    c: 'sky',
    title: 'Static preview pipeline',
    body: 'The same Twig components render in a Twing-powered dev server with live reload — design components in milliseconds, no Drupal in the loop.',
  },
  {
    icon: 'lucide:shield-check',
    c: 'clay',
    title: 'Guardrails for editors',
    body: 'Props are schema-validated: enums become selects, images use the media library, repeatable content is real nested components. Editors can’t break the design.',
  },
];

const cMap: Record<string, { chip: string }> = {
  none: { chip: 'bg-primary-50 text-primary-700' },
  sky: { chip: 'bg-sky-50 text-sky-700' },
  clay: { chip: 'bg-clay-50 text-clay-700' },
  accent: { chip: 'bg-accent-50 text-accent-700' },
};

const stats = [
  { n: '24', l: 'Canvas-ready components' },
  { n: '5', l: 'demo pages on install' },
  { n: '0', l: 'CDN dependencies' },
  { n: 'GPL', l: 'open source, like Drupal' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DrupalX — the modern Drupal starter for Canvas</title>
    <meta
      name="description"
      content="DrupalX is a Drupal 11 project template built around Canvas (Experience Builder) and a Tailwind v4 component library — a real design system your editors compose with."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href="https://drupalx.dev/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="DrupalX — the modern Drupal starter for Canvas" />
    <meta property="og:description" content="Drupal 11 + Canvas + a Tailwind v4 design system. ddev install lands a complete five-page demo site." />
    <meta property="og:image" content="/img/starter-blue.webp" />
  </head>

  <body class="bg-white">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[60] focus:bg-white focus:px-4 focus:py-2 focus:rounded-lg">Skip to content</a>

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-primary-100">
      <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-6 h-16">
        <a href="#" class="flex items-center gap-2.5" aria-label="DrupalX — top">
          <img src="/favicon.svg" alt="" class="w-8 h-8 rounded-lg" />
          <span class="font-display font-semibold text-lg text-primary-800">DrupalX</span>
        </a>
        <nav class="max-lg:hidden" aria-label="Sections">
          <ul class="flex items-center gap-1">
            {['Features', 'Theming', 'Workflow', 'Editor'].map((t) => (
              <li>
                <a href={`#${t.toLowerCase()}`} class="px-3 py-2 rounded-lg text-[0.95rem] font-semibold text-ink-700 hover:text-primary-700 hover:bg-primary-50 transition-colors">{t}</a>
              </li>
            ))}
          </ul>
        </nav>
        <a href={GITHUB} class="inline-flex items-center gap-2 rounded-full bg-primary-700 px-5 py-2 text-sm font-semibold text-white hover:bg-primary-800 transition-colors">
          <Icon name="lucide:github" class="size-4" aria-hidden="true" />
          GitHub
        </a>
      </div>
    </header>

    <main id="main">
      <!-- ── Hero ─────────────────────────────────────────────────── -->
      <section class="brand-glow relative overflow-hidden">
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
          <div>
            <p class="eyebrow text-accent-300">Drupal 11 · Canvas · Tailwind v4</p>
            <h1 class="display-hero mt-4 text-white">
              The Drupal starter your editors will <span class="text-accent-400">actually love</span>
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-primary-100">
              DrupalX pairs Canvas (Experience Builder) with a Tailwind v4 component
              library — a real design system, composed page by page in the CMS.
              One <code class="text-accent-200">ddev install</code> lands a complete five-page demo site.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href={GITHUB} class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-7 py-3.5 font-bold text-primary-900 hover:bg-accent-400 transition-colors">
                Get started on GitHub
                <Icon name="lucide:arrow-right" class="size-5" aria-hidden="true" />
              </a>
              <a href="#workflow" class="inline-flex items-center gap-2 rounded-full border border-white/40 bg-white/10 px-7 py-3.5 font-semibold text-white backdrop-blur-sm hover:bg-white/20 transition-colors">
                How it works
              </a>
            </div>
          </div>

          <!-- Quick-start terminal card -->
          <div class="relative">
            <div class="absolute inset-0 translate-x-4 translate-y-4 rounded-2xl bg-accent-500/20" aria-hidden="true"></div>
            <div class="term relative p-6 shadow-2xl">
              <div class="flex gap-1.5 mb-4" aria-hidden="true">
                <span class="w-3 h-3 rounded-full bg-clay-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-accent-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-primary-400/80"></span>
              </div>
              <pre id="quickstart"><code><span class="cmt"># the whole thing, three commands</span>
<span class="prompt">$</span> git clone {GITHUB}.git
<span class="prompt">$</span> cd drupalx-project <span class="tok">&amp;&amp;</span> ddev start
<span class="prompt">$</span> ddev install
<span class="cmt"># → five-page demo site, admin / admin</span></code></pre>
              <button
                id="copy-btn"
                class="mt-4 inline-flex items-center gap-1.5 rounded-lg border border-white/20 px-3 py-1.5 text-xs font-semibold text-primary-100 hover:bg-white/10 transition-colors"
                data-copy={`git clone ${GITHUB}.git\ncd drupalx-project && ddev start\nddev install`}
              >
                <Icon name="lucide:copy" class="size-3.5" aria-hidden="true" />
                <span data-copy-label>Copy commands</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Stat strip inside the dark band -->
        <div class="border-t border-white/10">
          <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 sm:grid-cols-4 sm:divide-x divide-white/10 py-10">
            {stats.map((s) => (
              <div class="px-2 py-3 text-center">
                <p class="stat-num text-white">{s.n}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-[0.12em] text-primary-200">{s.l}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Features ─────────────────────────────────────────────── -->
      <section id="features" class="py-20 md:py-28" data-reveal>
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mb-12">
            <p class="eyebrow">Why DrupalX</p>
            <h2 class="display-xl mt-3">Everything a modern Drupal site needs, wired together</h2>
            <p class="mt-4 text-lg leading-relaxed text-ink-500">
              Not a blank theme — a working system. Design tokens, components, performance
              discipline, and the Canvas editing experience, shipped as one template.
            </p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {features.map((f) => (
              <article class="spark-card flex flex-col rounded-2xl border border-primary-100 bg-white p-6 shadow-sm">
                <span class={`mb-4 inline-flex w-12 h-12 items-center justify-center rounded-xl ${cMap[f.c].chip}`}>
                  <Icon name={f.icon} class="size-6" aria-hidden="true" />
                </span>
                <h3 class="text-xl font-bold text-primary-800">{f.title}</h3>
                <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-500">{f.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Theming ──────────────────────────────────────────────── -->
      <section id="theming" class="bg-primary-50 py-20 md:py-28" data-reveal>
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
              <p class="eyebrow">The theming system</p>
              <h2 class="display-xl mt-3">Rebrand in one file</h2>
              <p class="mt-4 text-lg leading-relaxed text-ink-500">
                Every brand decision is a token. Recolor the <code class="text-primary-700 font-semibold">@theme</code> block,
                swap the fonts, rebuild — the whole site re-skins. The two screenshots
                are the <em>same components</em>: the starter palette and a
                cedar-green city brand, one CSS block apart.
              </p>
              <div class="term mt-6 p-5">
                <pre><code><span class="cmt">/* src/css/global.css — the whole brand */</span>
<span class="tok">@theme</span> &#123;
  --color-primary-500: <span class="prompt">#2f6fc4</span>;
  --color-accent-500:  <span class="prompt">#dfab34</span>;
  --font-display: <span class="prompt">'Fraunces Variable'</span>;
  <span class="cmt">/* + sky & clay wayfinding families */</span>
&#125;</code></pre>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <figure>
                <img src="/img/starter-blue.webp" alt="The DrupalX demo homepage in the default blue starter brand" width="500" height="875" loading="lazy" class="rounded-2xl border border-primary-100 shadow-xl w-full" />
                <figcaption class="mt-2 text-center text-xs font-semibold uppercase tracking-[0.12em] text-ink-500">The starter</figcaption>
              </figure>
              <figure class="translate-y-6">
                <img src="/img/rebrand-green.webp" alt="The same components rebranded as a cedar-green municipal site" width="500" height="875" loading="lazy" class="rounded-2xl border border-primary-100 shadow-xl w-full" />
                <figcaption class="mt-2 text-center text-xs font-semibold uppercase tracking-[0.12em] text-ink-500">One token block later</figcaption>
              </figure>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Workflow ─────────────────────────────────────────────── -->
      <section id="workflow" class="py-20 md:py-28" data-reveal>
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mb-12">
            <p class="eyebrow">The workflow</p>
            <h2 class="display-xl mt-3">Install to editing in minutes</h2>
          </div>
          <ol class="grid gap-6 lg:grid-cols-3">
            <li class="rounded-2xl border border-primary-100 bg-white p-6 shadow-sm">
              <p class="stat-num text-accent-500" aria-hidden="true">1</p>
              <h3 class="mt-2 text-lg font-bold">Install</h3>
              <p class="mt-2 text-[0.95rem] text-ink-500"><code class="font-semibold text-primary-700">ddev install</code> builds Drupal 11 + Canvas and imports the five-page demo — pages, media, menus, the lot.</p>
            </li>
            <li class="rounded-2xl border border-primary-100 bg-white p-6 shadow-sm">
              <p class="stat-num text-accent-500" aria-hidden="true">2</p>
              <h3 class="mt-2 text-lg font-bold">Compose</h3>
              <p class="mt-2 text-[0.95rem] text-ink-500">Open any page in the Canvas editor. Drag components from the library, edit props as form fields, nest cards into grids.</p>
            </li>
            <li class="rounded-2xl border border-primary-100 bg-white p-6 shadow-sm">
              <p class="stat-num text-accent-500" aria-hidden="true">3</p>
              <h3 class="mt-2 text-lg font-bold">Extend</h3>
              <p class="mt-2 text-[0.95rem] text-ink-500">New component = one folder: a schema + a Twig file. Preview it in the live-reload static workbench, then <code class="font-semibold text-primary-700">drush cr</code> — it's in the editor.</p>
            </li>
          </ol>
        </div>
      </section>

      <!-- ── Editor ───────────────────────────────────────────────── -->
      <section id="editor" class="bg-primary-50 py-20 md:py-28" data-reveal>
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mb-10">
            <p class="eyebrow">The editing experience</p>
            <h2 class="display-xl mt-3">What your editors see</h2>
            <p class="mt-4 text-lg leading-relaxed text-ink-500">
              The real Canvas editor on the real demo site: the page tree on the left,
              the live page in the middle, and a component's settings as a plain form on
              the right — style variants as dropdowns, links with autocomplete, images
              from the media library.
            </p>
          </div>
          <img
            src="/img/editor.webp"
            alt="The Drupal Canvas editor showing the DrupalX demo homepage with the component layers panel and a Button component's settings form open"
            width="1400" height="856" loading="lazy"
            class="rounded-2xl border border-primary-200 shadow-2xl w-full"
          />
        </div>
      </section>

      <!-- ── CTA ──────────────────────────────────────────────────── -->
      <section class="brand-glow py-20 md:py-28" data-reveal>
        <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="eyebrow justify-center text-accent-300">Open source</p>
          <h2 class="display-xl mx-auto mt-3 max-w-3xl text-white">GPL, like Drupal itself</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-primary-100">
            Clone it, rebrand it, ship it. If you build something good, we'd love to see it.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href={GITHUB} class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-7 py-3.5 font-bold text-primary-900 hover:bg-accent-400 transition-colors">
              <Icon name="lucide:github" class="size-5" aria-hidden="true" />
              nextagencyio/drupalx-project
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- ── Footer ─────────────────────────────────────────────────── -->
    <footer class="bg-primary-900 text-primary-100">
      <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm">
        <p class="flex items-center gap-2">
          <img src="/favicon.svg" alt="" class="w-5 h-5 rounded" />
          <span class="font-display font-semibold text-white">DrupalX</span>
          <span class="text-primary-300">· Drupal 11 + Canvas + Tailwind v4</span>
        </p>
        <p class="text-primary-300">
          <a href={GITHUB} class="hover:text-white underline underline-offset-4">GitHub</a>
          <span aria-hidden="true"> · </span>GPL-2.0-or-later
        </p>
      </div>
    </footer>

    <script>
      // Scroll-reveal (progressive enhancement — nothing hidden without JS).
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        document.documentElement.classList.add('reveal-ready');
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }),
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
      }

      // Copy the quick-start commands.
      const btn = document.getElementById('copy-btn');
      btn?.addEventListener('click', async () => {
        const label = btn.querySelector('[data-copy-label]');
        try {
          await navigator.clipboard.writeText(btn.getAttribute('data-copy') ?? '');
          if (label) label.textContent = 'Copied!';
          setTimeout(() => { if (label) label.textContent = 'Copy commands'; }, 2000);
        } catch { /* clipboard unavailable */ }
      });
    </script>
  </body>
</html>
